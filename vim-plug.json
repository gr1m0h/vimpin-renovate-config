{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Renovate managers for vim-plug specs that pin commit + tag (or branch).",
  "customManagers": [
    {
      "customType": "regex",
      "description": "vim-plug: tag-tracked pin",
      "managerFilePatterns": [
        "\\.vim$",
        "\\.vimrc$",
        "init\\.vim$"
      ],
      "matchStrings": [
        "Plug\\s+['\"](?<depName>[^'\"]+/[^'\"]+)['\"]\\s*,\\s*\\{[^}]*?['\"]commit['\"]\\s*:\\s*['\"](?<currentDigest>[a-f0-9]{40})['\"][^}]*?['\"]tag['\"]\\s*:\\s*['\"](?<currentValue>[^'\"]+)['\"]"
      ],
      "datasourceTemplate": "github-tags",
      "packageNameTemplate": "{{depName}}"
    },
    {
      "customType": "regex",
      "description": "vim-plug: branch-tracked pin",
      "managerFilePatterns": [
        "\\.vim$",
        "\\.vimrc$",
        "init\\.vim$"
      ],
      "matchStrings": [
        "Plug\\s+['\"](?<depName>[^'\"]+/[^'\"]+)['\"]\\s*,\\s*\\{[^}]*?['\"]commit['\"]\\s*:\\s*['\"](?<currentDigest>[a-f0-9]{40})['\"][^}]*?['\"]branch['\"]\\s*:\\s*['\"](?<currentValue>[^'\"]+)['\"]"
      ],
      "datasourceTemplate": "git-refs",
      "packageNameTemplate": "https://github.com/{{depName}}"
    }
  ]
}
