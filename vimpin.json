{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Renovate managers for vimpin.toml manifests. Supports tag-tracked, branch-tracked, and tag-only (no commit) entries.",
  "customManagers": [
    {
      "customType": "regex",
      "description": "vimpin.toml: tag-tracked entries (commit + tag)",
      "managerFilePatterns": [
        "(^|/)vimpin\\.toml$"
      ],
      "matchStrings": [
        "repo\\s*=\\s*\"(?<depName>[^\"]+)\"\\s*\\ncommit\\s*=\\s*\"(?<currentDigest>[a-f0-9]{40})\"\\s*\\ntag\\s*=\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "github-tags",
      "packageNameTemplate": "{{depName}}"
    },
    {
      "customType": "regex",
      "description": "vimpin.toml: branch-tracked entries (commit + branch, no tag)",
      "managerFilePatterns": [
        "(^|/)vimpin\\.toml$"
      ],
      "matchStrings": [
        "repo\\s*=\\s*\"(?<depName>[^\"]+)\"\\s*\\ncommit\\s*=\\s*\"(?<currentDigest>[a-f0-9]{40})\"\\s*\\nbranch\\s*=\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "git-refs",
      "packageNameTemplate": "https://github.com/{{depName}}"
    },
    {
      "customType": "regex",
      "description": "vimpin.toml: tag-only entries (tag without commit; vimpin pin will fill in commit later, Renovate bumps the tag here)",
      "managerFilePatterns": [
        "(^|/)vimpin\\.toml$"
      ],
      "matchStrings": [
        "repo\\s*=\\s*\"(?<depName>[^\"]+)\"\\s*\\ntag\\s*=\\s*\"(?<currentValue>[^\"]+)\"(?!\\s*\\ncommit)"
      ],
      "datasourceTemplate": "github-tags",
      "packageNameTemplate": "{{depName}}"
    }
  ]
}
