{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Renovate managers for lazy.nvim plugin specs pinned in vimpin's canonical form: { \"owner/repo\", commit = \"<40-hex>\" } followed by a -- tag: X or -- branch: X annotation. The commit must appear directly after the repo positional (separated only by whitespace and the comma); other spec fields belong after the commit.",
  "customManagers": [
    {
      "customType": "regex",
      "description": "Lua spec: tag-tracked pin (canonical comment-form)",
      "managerFilePatterns": [
        "\\.lua$"
      ],
      "matchStrings": [
        "\"(?<depName>[^\"]+/[^\"]+)\"\\s*,\\s*commit\\s*=\\s*\"(?<currentDigest>[a-f0-9]{40})\"[^\\n]*?--\\s*tag:\\s*(?<currentValue>\\S+)"
      ],
      "datasourceTemplate": "github-tags",
      "packageNameTemplate": "{{depName}}"
    },
    {
      "customType": "regex",
      "description": "Lua spec: branch-tracked pin (canonical comment-form)",
      "managerFilePatterns": [
        "\\.lua$"
      ],
      "matchStrings": [
        "\"(?<depName>[^\"]+/[^\"]+)\"\\s*,\\s*commit\\s*=\\s*\"(?<currentDigest>[a-f0-9]{40})\"[^\\n]*?--\\s*branch:\\s*(?<currentValue>\\S+)"
      ],
      "datasourceTemplate": "git-refs",
      "packageNameTemplate": "https://github.com/{{depName}}"
    }
  ]
}
