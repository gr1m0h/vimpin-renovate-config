{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Renovate managers for lazy.nvim / packer.nvim Lua plugin specs. Supports both pinned (commit + tag/branch/version) and tracking-only (tag or version) entries. Within an entry, fields must appear consecutively separated by commas.",
  "customManagers": [
    {
      "customType": "regex",
      "description": "Lua spec: tag-tracked pin (commit + tag, either order)",
      "managerFilePatterns": [
        "\\.lua$"
      ],
      "matchStrings": [
        "\"(?<depName>[^\"]+/[^\"]+)\"\\s*,\\s*commit\\s*=\\s*\"(?<currentDigest>[a-f0-9]{40})\"\\s*,\\s*tag\\s*=\\s*\"(?<currentValue>[^\"]+)\"",
        "\"(?<depName>[^\"]+/[^\"]+)\"\\s*,\\s*tag\\s*=\\s*\"(?<currentValue>[^\"]+)\"\\s*,\\s*commit\\s*=\\s*\"(?<currentDigest>[a-f0-9]{40})\""
      ],
      "datasourceTemplate": "github-tags",
      "packageNameTemplate": "{{depName}}"
    },
    {
      "customType": "regex",
      "description": "Lua spec: semver-tracked pin (commit + version, either order)",
      "managerFilePatterns": [
        "\\.lua$"
      ],
      "matchStrings": [
        "\"(?<depName>[^\"]+/[^\"]+)\"\\s*,\\s*commit\\s*=\\s*\"(?<currentDigest>[a-f0-9]{40})\"\\s*,\\s*version\\s*=\\s*\"(?<currentValue>[^\"]+)\"",
        "\"(?<depName>[^\"]+/[^\"]+)\"\\s*,\\s*version\\s*=\\s*\"(?<currentValue>[^\"]+)\"\\s*,\\s*commit\\s*=\\s*\"(?<currentDigest>[a-f0-9]{40})\""
      ],
      "datasourceTemplate": "github-tags",
      "packageNameTemplate": "{{depName}}",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Lua spec: branch-tracked pin (commit + branch, either order)",
      "managerFilePatterns": [
        "\\.lua$"
      ],
      "matchStrings": [
        "\"(?<depName>[^\"]+/[^\"]+)\"\\s*,\\s*commit\\s*=\\s*\"(?<currentDigest>[a-f0-9]{40})\"\\s*,\\s*branch\\s*=\\s*\"(?<currentValue>[^\"]+)\"",
        "\"(?<depName>[^\"]+/[^\"]+)\"\\s*,\\s*branch\\s*=\\s*\"(?<currentValue>[^\"]+)\"\\s*,\\s*commit\\s*=\\s*\"(?<currentDigest>[a-f0-9]{40})\""
      ],
      "datasourceTemplate": "git-refs",
      "packageNameTemplate": "https://github.com/{{depName}}"
    },
    {
      "customType": "regex",
      "description": "Lua spec: tag-only tracking (tag without commit; bumps the tag value when a newer release appears)",
      "managerFilePatterns": [
        "\\.lua$"
      ],
      "matchStrings": [
        "\\{\\s*\"(?<depName>[^\"]+/[^\"]+)\"\\s*,\\s*tag\\s*=\\s*\"(?<currentValue>[^\"]+)\"\\s*[,}]"
      ],
      "datasourceTemplate": "github-tags",
      "packageNameTemplate": "{{depName}}"
    },
    {
      "customType": "regex",
      "description": "Lua spec: version-only tracking (semver range without commit)",
      "managerFilePatterns": [
        "\\.lua$"
      ],
      "matchStrings": [
        "\\{\\s*\"(?<depName>[^\"]+/[^\"]+)\"\\s*,\\s*version\\s*=\\s*\"(?<currentValue>[^\"]+)\"\\s*[,}]"
      ],
      "datasourceTemplate": "github-tags",
      "packageNameTemplate": "{{depName}}",
      "versioningTemplate": "semver"
    }
  ]
}
